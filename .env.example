# Qdrant Database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Local embedding API (fastembed backend)
EMBEDDING_HOST=http://localhost:8001
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Hugging Face token (optional, used for model downloads if needed)
# HF_TOKEN=your-hf-token-here

# Modular LLM Configuration
# Choose LLM provider: "custom" (for self-hosted vLLM/Ollama/etc.) or "openai"
LLM_PROVIDER=openai

# Standard OpenAI configuration (Default option)
OPENAI_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o-mini

# 2. Custom Deployed LLM configuration (vLLM, Ollama, self-hosted API compatible with OpenAI)
# Set LLM_PROVIDER=custom to use these options
# LLM_API_KEY=your-custom-llm-api-key
# LLM_BASE_URL=http://localhost:8002/v1
# LLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct